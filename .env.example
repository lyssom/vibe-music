# vibe-echo configuration
# Copy this to .env and fill in your values.

# MiniMax API key (recommended)
# Get yours at: https://platform.minimax.chat/
MINIMAX_API_KEY=

# OR use OpenAI-compatible API key
# OPENAI_API_KEY=

# Development fallback (requires VIBE_DEV_FALLBACK=1)
# VIBE_DEV_KEY=
# VIBE_DEV_FALLBACK=0